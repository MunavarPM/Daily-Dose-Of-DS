class soultion {
    func returnArray (numbers: [Int], target: Int) -> [Int] {
        
        for i in 0..<numbers.count {
            for j in i+1..<numbers.count {
                if numbers[i] + numbers[j] == target {
                    return [i, j]
                }
            }
        }
        return []
    }
}

